{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "omnisso",
  "main": "src/worker/index.ts",
  "compatibility_date": "2026-06-08",
  "keep_vars": true,
  "assets": {
    "directory": "./dist",
    "binding": "ASSETS",
    "not_found_handling": "single-page-application",
    "run_worker_first": [
      "/",
      "/api/*",
      "/authorize",
      "/token",
      "/.well-known/*",
      "/ui",
      "/ui/",
      "/ui/login"
    ]
  },
  "durable_objects": {
    "bindings": [
      {
        "name": "AUTH_CODES",
        "class_name": "AuthCodeStore"
      }
    ]
  },
  "migrations": [
    {
      "tag": "v1",
      "new_sqlite_classes": [
        "AuthCodeStore"
      ]
    }
  ],
  "secrets": {
    "required": [
      "OIDC_CLIENT_SECRET",
      "OIDC_PRIVATE_JWK"
    ]
  },
  "vars": {
    "ISSUER": "https://sso.aicnio.com",
    "OIDC_CLIENT_ID": "openai-workspace",
    "OIDC_REDIRECT_URI": "https://external.auth.openai.com/sso/oidc/rxOnGtpO5HbiplDmonS6fxGLp/callback"
  }
}
